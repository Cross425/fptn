--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -1,6 +1,9 @@
 cmake_minimum_required(VERSION 3.16)
 project(fptn)

+option(USE_BORINGSSL "Use BoringSSL" OFF)
+option(USE_MBEDTLS "Use mbedTLS" ON)
+
 if (USE_CONAN)
     message(FATAL_ERROR "Conan is disabled for OpenWrt builds")
 endif()
@@ -20,7 +23,18 @@
 endif()

-if (USE_BORINGSSL)
-    find_package(BoringSSL REQUIRED)
-endif()
+if (USE_BORINGSSL)
+    find_package(BoringSSL REQUIRED)
+elseif (USE_MBEDTLS)
+    # OpenWrt: libcurl is built with mbedTLS by default, use the same TLS backend
+    find_package(MbedTLS REQUIRED)
+    include_directories(${MBEDTLS_INCLUDE_DIRS})
+    link_libraries(${MBEDTLS_LIBRARIES})
+else()
+    find_package(OpenSSL REQUIRED)
+endif()
