#!/bin/sh /etc/rc.common
USE_PROCD=1
START=90
STOP=10

PROG=/usr/sbin/fptn
CONF=/etc/fptn/token.json

start_service() {
	procd_open_instance
	procd_set_param command "$PROG" --token "$CONF"
	procd_set_param respawn 3600 5 5
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}
